# ============================================================
# VECY NETWORK — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a GitHub
# ============================================================

# --- OAuth (Manus / Login) ---
OAUTH_SERVER_URL=http://localhost:3000

# --- Base de Datos (Supabase PostgreSQL) ---
# La URL de conexión directa (para migraciones con Drizzle)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# La URL de conexión pooled (para la aplicación en runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"

# --- GitHub (opcional, para sincronización de fichas) ---
GITHUB_TOKEN=your_github_personal_access_token_here

# --- Control de Bot de WhatsApp ---
# Establece en "false" para deshabilitar el bot de WhatsApp (Puppeteer) localmente o en producción.
ENABLE_WHATSAPP_BOT=true
USE_WHATSAPP_CLOUD_API=false

# Modo Híbrido: Permite correr Puppeteer en paralelo solo para grupos si la API de Cloud está activa
ENABLE_PUPPETEER_FOR_GROUPS=false
WHATSAPP_OFFICIAL_DM_LINK="https://wa.me/your_official_meta_number_here"

# --- Credenciales Meta Developer (API de WhatsApp Cloud) ---
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here

